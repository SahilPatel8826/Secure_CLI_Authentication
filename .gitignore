```gitignore
# ===========================
# Go
# ===========================

*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.coverprofile
coverage.out

# Go workspace
go.work
go.work.sum

# ===========================
# Environment Variables
# ===========================

.env

# ===========================
# Build Output
# ===========================

bin/
dist/
build/
auth-cli

# ===========================
# Logs
# ===========================

*.log

# ===========================
# IDE
# ===========================

.vscode/
.idea/

# ===========================
# OS Files
# ===========================

.DS_Store
Thumbs.db

# ===========================
# Docker
# ===========================

docker-compose.override.yml

# ===========================
# Temporary Files
# ===========================

tmp/
temp/

# ===========================
# TOTP / QR Codes
# ===========================

qrcode.png

# ===========================
# Database Dumps
# ===========================

*.sql
*.dump
```
